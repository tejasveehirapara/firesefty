// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
 binaryTargets = ["native", "rhel-openssl-3.0.x"]
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
  MANAGER
}

enum POStatus {
  Created
  Discussion
  ReminderSent
  Confirmed
  Completed
  Cancelled
}

enum SaleStatus {
  QuotationSent
  Discussion
  Confirmed
  Completed
  Cancelled
}

model User {
  id          String           @id @default(cuid())
  firstName   String           @map("first_name")
  lastName    String           @map("last_name")
  role        Role             @default(USER)
  email       String           @unique
  password    String
  phone       String?
  isActive    Boolean          @default(true)  @map("is_active")
  isBlocked   Boolean          @default(false) @map("is_blocked")
  permissions UserPermission[]
  sessions    UserSession[]
  history     StatusHistory[]
  resetPasswordToken   String?          @map("reset_password_token")
  resetPasswordExpires DateTime?        @map("reset_password_expires")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt      @map("updated_at")

  @@map("users")
}

model Screen {
  id          String           @id @default(cuid())
  screenName  String           @map("screen_name")
  route       String           @unique
  order       Int             @default(1)
  permissions UserPermission[]

  @@map("screens")
}

model UserPermission {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  screenId String @map("screen_id")
  user     User   @relation(fields: [userId], references: [id])
  screen   Screen @relation(fields: [screenId], references: [id])
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime?      @updatedAt @map("updated_at")

  @@unique([userId, screenId])
  @@map("user_permissions")
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expireAt  DateTime @map("expire_at")
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@map("user_sessions")
}

model Product {
  id          String                 @id @default(cuid())
  name        String
  description String?
  price       Decimal?               @default(0.00) @db.Decimal(10, 2)
  vendors       VendorProductMapping[]
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  inventory     Inventory?
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  @@map("products")
}

model Vendor {
  id          String                 @id @default(cuid())
  name        String
  email       String                 @unique
  phoneNumber String                 @map("phone_number")
  products    VendorProductMapping[]
  purchases   Purchase[]
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  @@map("vendors")
}

model VendorProductMapping {
  id        String  @id @default(cuid())
  vendorId  String  @map("vendor_id")
  productId String  @map("product_id")
  vendor    Vendor  @relation(fields: [vendorId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@unique([vendorId, productId])
  @@map("vendor_product_mapping")
}

model Sale {
  id           String     @id @default(cuid())
  buyerName    String     @map("buyer_name")
  buyerPhone   String     @map("buyer_phone")
  buyerEmail   String?    @map("buyer_email")
  buyerAddress String?    @map("buyer_address")
  quotationDate DateTime   @default(now()) @map("quotation_date")
  items        SaleItem[]

  history     StatusHistory[]
  status      SaleStatus @default(QuotationSent)

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("sales")
}

model SaleItem {
  id          String   @id @default(cuid())
  saleId      String   @map("sale_id")
  productId   String   @map("product_id")
  quantity    Int
  unitPrice   Decimal?  @map("unit_price") @db.Decimal(10, 2)
  totalAmount Decimal?  @map("total_amount") @db.Decimal(10, 2)
  sale        Sale     @relation(fields: [saleId], references: [id])

  product     Product  @relation(fields: [productId], references: [id])
  status      SaleStatus @default(QuotationSent)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("sale_items")
}

model Purchase {
  id           String         @id @default(cuid())
  vendorId     String         @map("vendor_id")
  totalAmount  Decimal        @map("total_amount") @db.Decimal(10, 2)
  purchaseDate DateTime       @default(now()) @map("purchase_date")
  vendor       Vendor         @relation(fields: [vendorId], references: [id])
  items        PurchaseItem[]
  history       StatusHistory[]

  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  status       POStatus       @default(Created)
  @@map("purchases")
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String   @map("purchase_id")
  productId   String   @map("product_id")
  quantity    Int
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  totalAmount Decimal  @map("total_amount") @db.Decimal(10, 2)

  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime?      @updatedAt @map("updated_at")
  @@map("purchase_items")
}

model Inventory {
  id        String  @id @default(cuid())
  productId String  @unique @map("product_id")
  quantity  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id])
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime?      @updatedAt @map("updated_at")
  @@map("inventory_management")
}

model StatusHistory {
  id        String  @id @default(cuid())

  status    String

  purchaseOrderId  String?
  saleId           String?

  purchaseOrder    Purchase? @relation(fields: [purchaseOrderId], references: [id])
  sale             Sale?          @relation(fields: [saleId], references: [id])

  createdBy String @map("created_by")
  user      User   @relation(fields: [createdBy], references: [id])
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
}
